# =====================================================
# 号码隐私保护系统（FreeSWITCH版）- 环境变量配置
# 复制为 .env 后填写，不要提交到版本控制
# =====================================================

# ── 映射服务 ──────────────────────────────────────────

DATABASE_URL=sqlite:////data/mask.db
# DATABASE_URL=postgresql+asyncpg://maskuser:yourpassword@localhost:5432/maskdb

# 生成方式：python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY
GATEWAY_API_KEY=CHANGE_ME_GATEWAY_KEY

# Token 默认有效期（天），留空=永不过期
DEFAULT_TTL_DAYS=

# ── FreeSWITCH 相关 ────────────────────────────────────

# 映射服务地址（FS 和映射服务同机，保持默认即可）
MASK_SERVICE_URL=http://127.0.0.1:8080

# 线路商配置
CARRIER_HOST=sip.your-carrier.com
CARRIER_USERNAME=your_trunk_username
CARRIER_PASSWORD=your_trunk_password
